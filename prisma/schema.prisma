generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tender {
  id           Int     @id @default(autoincrement())
  title        String
  region       String
  trade        String
  priority     String
  status       String
  manualReview Boolean
  value        Int
  createdAt    DateTime @default(now())
}

model PipelineEntry {
  id        Int     @id @default(autoincrement())
  title     String
  stage     String
  value     Int
  createdAt DateTime @default(now())
}
